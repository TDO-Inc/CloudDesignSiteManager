# --- Database ---
# SQL Server ADO.NET connection string (Azure SQL DB or local SQL Server)
# Local dev: use Docker image mcr.microsoft.com/mssql/server or a local SQL Server instance.
DATABASE_URL=Server=localhost,1433;Database=tdo_portal;User Id=sa;Password=YourStrong@Password1;Encrypt=False;TrustServerCertificate=True;

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# --- Anthropic (AI assistant) ---
# Get a key at console.anthropic.com. Leave blank to disable the assistant gracefully.
ANTHROPIC_API_KEY=

# --- Resend (email) ---
RESEND_API_KEY=
EMAIL_FROM=webadmin@tdo4endo.com
EMAIL_FROM_NAME=TDO Software

# --- Azure Blob Storage ---
# In development you can leave these blank to use a local stub.
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=tdo-portal-files

# --- Virus scanning ---
# noop | (future: defender, clamav)
SCAN_PROVIDER=noop

# --- Admin seed ---
ADMIN_PASSWORD=replace-with-a-strong-password
# Set to "true" to skip the demo orgs/projects/briefs/files when seeding (e.g. in prod).
# Leave unset (or "false") for dev to populate the dashboard with sample content.
SKIP_DEMO_DATA=

# --- Auth providers ---
# dev | (future: oidc, saml)
STAFF_AUTH_PROVIDER=dev
# Dev provider — auto-logs in as this staff user
DEV_STAFF_EMAIL=jared.ardine@tdo4endo.com
DEV_STAFF_NAME=Jared Ardine

# --- Sentry (optional in dev) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Magic link ---
MAGIC_LINK_TTL_MINUTES=15
